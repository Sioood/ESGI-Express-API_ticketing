    {
      "name": "Tickets Scenario",
      "item": [
        {
          "name": "Alice creates ticket",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{ALICE_TOKEN}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/tickets",
              "host": ["{{baseUrl}}"],
              "path": ["tickets"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Problème d'accès VPN\",\n  \"description\": \"Impossible de me connecter au VPN.\",\n  \"category\": \"access\",\n  \"priority\": \"high\"\n}"
            }
          }
        },
        {
          "name": "Sophie list all tickets",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{SOPHIE_TOKEN}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/tickets",
              "host": ["{{baseUrl}}"],
              "path": ["tickets"]
            }
          }
        },
        {
          "name": "Sophie assign ticket to herself",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{SOPHIE_TOKEN}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/tickets/{{TICKET_ID}}/assign",
              "host": ["{{baseUrl}}"],
              "path": ["tickets", "{{TICKET_ID}}", "assign"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"assigneeId\": {{SOPHIE_ID}}\n}"
            }
          }
        },
        {
          "name": "Sophie set status to in_progress",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{SOPHIE_TOKEN}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/tickets/{{TICKET_ID}}/status",
              "host": ["{{baseUrl}}"],
              "path": ["tickets", "{{TICKET_ID}}", "status"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"in_progress\"\n}"
            }
          }
        },
        {
          "name": "Sophie set status to resolved",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{SOPHIE_TOKEN}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/tickets/{{TICKET_ID}}/status",
              "host": ["{{baseUrl}}"],
              "path": ["tickets", "{{TICKET_ID}}", "status"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"resolved\"\n}"
            }
          }
        },
        {
          "name": "Sophie adds internal comment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{SOPHIE_TOKEN}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/tickets/{{TICKET_ID}}/comments",
              "host": ["{{baseUrl}}"],
              "path": ["tickets", "{{TICKET_ID}}", "comments"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"Analyse effectuée, problème identifié sur le serveur VPN.\",\n  \"internal\": true\n}"
            }
          }
        },
        {
          "name": "Alice view ticket",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{ALICE_TOKEN}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/tickets/{{TICKET_ID}}",
              "host": ["{{baseUrl}}"],
              "path": ["tickets", "{{TICKET_ID}}"]
            }
          }
        },
        {
          "name": "Alice closes ticket",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{ALICE_TOKEN}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/tickets/{{TICKET_ID}}/status",
              "host": ["{{baseUrl}}"],
              "path": ["tickets", "{{TICKET_ID}}", "status"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"closed\"\n}"
            }
          }
        },
        {
          "name": "Alice cancels open ticket",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{ALICE_TOKEN}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/tickets/{{OPEN_TICKET_ID}}/status",
              "host": ["{{baseUrl}}"],
              "path": ["tickets", "{{OPEN_TICKET_ID}}", "status"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"cancelled\"\n}"
            }
          }
        }
      ]
    }
